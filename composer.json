{
    "name": "leantime/time-table",
    "description": "A time table for leantime",
    "license": "MIT",
    "type": "leantime-plugin",
    "version": "4.3.0",
    "authors": [
        {
            "name": "Jeppe Krogh",
            "email": "kjej@aarhus.dk"
        },
        {
            "name": "Sine Jespersen",
            "email": "sinje@aarhus.dk"
        }
    ],
    "homepage": "https://github.com/ITK-Leantime/leantime-timetable",
    "require-dev": {
        "ergebnis/composer-normalize": "^2.42",
        "friendsofphp/php-cs-fixer": "^3.51",
        "leantime/leantime": "^3.4.5",
        "phpcsstandards/phpcsextra": "^1.2",
        "phpstan/phpstan": "^1.10",
        "phpunit/phpunit": "^10.5",
        "psr/log": "^1 || ^2 || ^3",
        "squizlabs/php_codesniffer": "^3.9",
        "zebra-north/phpcs-short-types": "^1.0"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "ergebnis/composer-normalize": true,
            "metasyntactical/composer-plugin-license-check": true,
            "php-http/discovery": true
        },
        "audit": {
            "_comment": {
                "content": "Ignore Laravel 11.x advisories: leantime/leantime is dev-only for static analysis, not a runtime dependency"
            },
            "ignore": {
                "PKSA-m5cs-t1y6-qpcs": "Laravel 11.x advisory; this plugin has no runtime require, leantime/leantime is dev-only for static analysis context.",
                "PKSA-3r5d-mb8f-1qw9": "Laravel 11.x advisory; this plugin has no runtime require, leantime/leantime is dev-only for static analysis context.",
                "PKSA-mdq4-51ck-6kdq": "Laravel 11.x advisory; this plugin has no runtime require, leantime/leantime is dev-only for static analysis context.",
                "PKSA-8qx3-n5y5-vvnd": "Laravel 11.x advisory; this plugin has no runtime require, leantime/leantime is dev-only for static analysis context."
            }
        }
    },
    "scripts": {
        "code-analysis": [
            "@code-analysis/phpstan"
        ],
        "code-analysis/phpstan": [
            "phpstan analyse"
        ],
        "coding-standards-apply": [
            "@coding-standards-apply/phpcbf"
        ],
        "coding-standards-apply/phpcbf": [
            "phpcbf ."
        ],
        "coding-standards-check": [
            "@coding-standards-check/phpcs"
        ],
        "coding-standards-check/phpcs": [
            "phpcs ."
        ]
    }
}
